{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/auth/{**catch-all}" }
        ]
      },
      "auth-swagger": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/swagger/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v1/user/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/user/{**catch-all}" }
        ]
      },
      "user-swagger": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/swagger/user/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/v1/chat/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/chat/{**catch-all}" }
        ]
      },
      "chat-hub-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/chatHub/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/chatHub/{**catch-all}" }
        ]
      },
      "chat-swagger": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/swagger/chat/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/api/v1/post/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/post/{**catch-all}" }
        ]
      },
      "post-swagger": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/swagger/post/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5201"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": {
            "Address": "http://localhost:5202"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-service": {
            "Address": "http://localhost:5203"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "post-service": {
            "Address": "http://localhost:5204"
          }
        }
      }
    }
  }
}
